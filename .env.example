APP_NAME=ShieldPanel
APP_VERSION=0.1.0
APP_ENV=production
SHIELDPANEL_ROOT=/opt/shieldpanel

SERVER_HOST=0.0.0.0
SERVER_PORT=8080
PANEL_PORT=8080
PUBLIC_URL=http://your-vps-ip:8080
FRONTEND_DIST_DIR=/opt/shieldpanel/frontend/dist

DATABASE_URL=postgres://shieldpanel:change-me-db-password@127.0.0.1:5432/shieldpanel?sslmode=disable
DB_MAX_CONNS=20
DB_MIN_CONNS=2

REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=shieldpanel:

AUTH_SESSION_COOKIE=shieldpanel_session
AUTH_CSRF_COOKIE=shieldpanel_csrf
AUTH_SESSION_TTL=12h
AUTH_REMEMBER_TTL=720h
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=
AUTH_BCRYPT_COST=12

SESSION_SECRET=change-me-session-secret
CHALLENGE_SECRET=change-me-challenge-secret
TRUSTED_PROXY_MODE=false
TRUSTED_PROXY_HEADERS=CF-Connecting-IP,X-Forwarded-For
AUTO_BAN_THRESHOLD=8
AUTO_BAN_WINDOW=15m
AUTO_BAN_TTL=30m
CHALLENGE_TTL=15m
CHALLENGE_GRACE_TTL=12h
ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,HEAD,OPTIONS

NGINX_ENABLED=true
NGINX_BIN=/usr/sbin/nginx
NGINX_CONFIG_PATH=/etc/nginx/nginx.conf
NGINX_SITES_AVAILABLE=/etc/nginx/shieldpanel/sites-available
NGINX_SITES_ENABLED=/etc/nginx/shieldpanel/sites-enabled
NGINX_ZONES_PATH=/etc/nginx/conf.d/shieldpanel-zones.conf
NGINX_TEMPLATES_DIR=/opt/shieldpanel/deploy/nginx/templates
NGINX_ACME_WEBROOT=/var/www/shieldpanel/acme
PANEL_UPSTREAM_URL=http://127.0.0.1:8080
NGINX_RELOAD_ON_CHANGE=true

DEFAULT_LANGUAGE=en
DEFAULT_PROTECTION_MODE=basic
DEFAULT_RATE_LIMIT_RPS=20
DEFAULT_RATE_LIMIT_BURST=40
DEFAULT_CHALLENGE_MODE=cookie

MIGRATIONS_DIR=/opt/shieldpanel/backend/migrations
DATA_DIR=/opt/shieldpanel/data
LOG_DIR=/var/log/shieldpanel
ISSUE_CERT_SCRIPT=/opt/shieldpanel/deploy/scripts/issue_cert.sh
RENEW_CERT_SCRIPT=/opt/shieldpanel/deploy/scripts/renew_cert.sh
LETSENCRYPT_EMAIL=admin@example.com
