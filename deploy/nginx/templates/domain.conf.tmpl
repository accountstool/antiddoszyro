# Reference domain vhost template for ShieldPanel managed domains.
# Runtime configs are generated by the Go backend into:
#   /etc/nginx/shieldpanel/sites-available/<domain>.conf

server {
    listen 80;
    server_name {{ .Domain.Name }};
    location ^~ /.well-known/acme-challenge/ {
        root {{ .ACMEWebroot }};
    }
    location / {
        auth_request /__shieldpanel_check;
        error_page 401 = @shieldpanel_challenge;
        error_page 403 = @shieldpanel_block;
        proxy_pass {{ .OriginURL }};
    }
}
