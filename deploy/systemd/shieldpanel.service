[Unit]
Description=ShieldPanel backend service
After=network.target postgresql.service redis-server.service
Wants=postgresql.service redis-server.service

[Service]
Type=simple
User=shieldpanel
Group=shieldpanel
WorkingDirectory=/opt/shieldpanel
EnvironmentFile=/etc/shieldpanel/shieldpanel.env
ExecStart=/opt/shieldpanel/bin/shieldpanel
Restart=always
RestartSec=5
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
